---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import PostCard from "../components/PostCard.astro";
import { prototypes, roadmap, site } from "../data/site";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);

const postHref = (id: string) => `/blog/${id.replace(/\.md$/, "")}/`;
---

<BaseLayout>
  <section class="hero compact-hero">
    <div>
      <p class="eyebrow">Personal Knowledge System</p>
      <h1>个人知识库与产品实验室</h1>
      <p class="hero-text">
        我是 WangAo-0。这里用于沉淀技术路线、博客文章、AI 与 Agent 产品原型，以及长期思考。
      </p>
      <div class="actions">
        <a class="button primary" href="/blog/">进入博客目录</a>
        <a class="button ghost" href={site.resumeUrl}>PDF 简历</a>
      </div>
    </div>

    <aside class="hero-visual knowledge-board" aria-label="网站内容地图">
      <div class="board-topline">
        <span>WangAo-0</span>
        <strong>Knowledge Map</strong>
      </div>
      <div class="map-grid">
        <a class="map-card main-map-card" href="/blog/">
          <span>Blog</span>
          <strong>个人博客</strong>
          <p>按文件夹目录组织网络、数据库、系统、AI 和产品原型文章。</p>
        </a>
        <a class="map-card" href="/roadmap/">
          <span>Roadmap</span>
          <strong>技术路线</strong>
          <p>从 Web 基础到 AI 工程，再到可交付产品。</p>
        </a>
        <a class="map-card" href="/prototypes/">
          <span>Prototype</span>
          <strong>产品原型</strong>
          <p>Agent 程序员包、理财平台、信息洞察和多 Agent 协作。</p>
        </a>
        <a class="map-card" href="/contact/">
          <span>Contact</span>
          <strong>联系方式</strong>
          <p>邮箱、微信、资助二维码和自媒体平台入口。</p>
        </a>
      </div>
      <div class="board-footer">
        <span>Markdown posts</span>
        <span>Astro static site</span>
        <span>GitHub Pages</span>
      </div>
    </aside>
  </section>

  <section id="about" class="section">
    <SectionHeader
      eyebrow="About"
      title="个人简介"
      description="先保留最重要的信息，后续可以把更正式的经历放进 PDF 简历。"
    />
    <div class="grid-2">
      <article class="card">
        <p class="card-kicker">Profile</p>
        <h3>WangAo-0</h3>
        <p>
          我关注技术学习、AI 工程、自动化开发和个人信息系统，希望把零散探索整理成可复用的文章、工具和产品原型。
        </p>
        <a class="text-link" href={site.resumeUrl}>查看 PDF 简历</a>
      </article>
      <article class="card">
        <p class="card-kicker">Current Focus</p>
        <h3>从博客到产品</h3>
        <p>
          当前网站不是一次性的作品展示，而是持续记录：技术路线、博客分类、Agent 产品原型，以及每次实践后的复盘。
        </p>
      </article>
    </div>
  </section>

  <section class="section">
    <SectionHeader eyebrow="Roadmap" title="技术 Roadmap" />
    <ol class="roadmap-list">
      {roadmap.slice(0, 3).map((item) => (
        <li class="card roadmap-item">
          <span class="roadmap-stage">{item.stage}</span>
          <div>
            <h3>{item.title}</h3>
            <ul>
              {item.items.map((entry) => <li>{entry}</li>)}
            </ul>
          </div>
        </li>
      ))}
    </ol>
    <div class="actions">
      <a class="button ghost" href="/roadmap/">查看完整 roadmap</a>
    </div>
  </section>

  <section class="section">
    <SectionHeader
      eyebrow="Blog"
      title="个人博客"
      description="博客按文件夹目录组织，方便以后按网络、数据库、系统、AI 和产品原型检索。"
      wide
    />
    <div class="post-grid">
      {posts.map((post, index) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          href={postHref(post.id)}
          category={post.data.subcategory || post.data.category}
          pubDate={post.data.pubDate}
          featured={index === 0}
        />
      ))}
    </div>
  </section>

  <section class="section">
    <SectionHeader
      eyebrow="Prototypes"
      title="产品原型"
      description="这里记录值得长期推进的产品想法，尤其是 Agent、自动化和个性化信息系统。"
      wide
    />
    <div class="prototype-grid">
      {prototypes.slice(0, 2).map((prototype) => (
        <article class="card">
          <p class="card-kicker">{prototype.category}</p>
          <h3>{prototype.title}</h3>
          <p>{prototype.description}</p>
          <ul class="scope-list">
            {prototype.scope.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
    <div class="actions">
      <a class="button ghost" href="/prototypes/">查看全部原型</a>
    </div>
  </section>

  <section class="contact-section">
    <div>
      <p class="eyebrow">Contact</p>
      <h2>从文章、代码或想法开始交流。</h2>
      <p>邮箱、微信、资助二维码和自媒体平台入口集中放在联系方式页面。</p>
    </div>
    <div class="contact-actions">
      <a class="button primary" href={`mailto:${site.email}`}>发送邮件</a>
      <a class="button ghost" href="/contact/">联系方式</a>
    </div>
  </section>
</BaseLayout>
