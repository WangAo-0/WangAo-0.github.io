---
import BaseLayout from "../layouts/BaseLayout.astro";
import { roadmap } from "../data/site";
---

<BaseLayout title="技术 Roadmap | WangAo-0" description="WangAo-0 的技术学习与产品推进路线。">
  <section class="page-shell">
    <div class="page-heading wide-heading">
      <p class="eyebrow">Roadmap</p>
      <h1>技术 Roadmap</h1>
      <p>这不是固定课程表，而是一个会随着实践更新的路线图：先打基础，再做系统，最后落到产品原型。</p>
    </div>
    <ol class="roadmap-list">
      {roadmap.map((item) => (
        <li class="card roadmap-item">
          <span class="roadmap-stage">{item.stage}</span>
          <div>
            <h3>{item.title}</h3>
            <ul>
              {item.items.map((entry) => <li>{entry}</li>)}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>
