---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
---

<BaseLayout title="联系方式 | WangAo-0" description="WangAo-0 的邮箱、微信、资助二维码和视频平台链接。">
  <section class="page-shell">
    <div class="page-heading">
      <p class="eyebrow">Contact</p>
      <h1>联系方式</h1>
      <p>这里集中放置邮箱、微信、资助二维码和自媒体视频平台链接。二维码现在是占位图，替换 `public/media/` 下的图片即可。</p>
    </div>
    <div class="contact-grid">
      <article class="media-card">
        <p class="card-kicker">Email</p>
        <h3>邮箱</h3>
        <p>{site.email}</p>
        <a class="text-link" href={`mailto:${site.email}`}>发送邮件</a>
      </article>
      <article class="media-card">
        <p class="card-kicker">WeChat</p>
        <h3>微信</h3>
        <img class="qr" src="/media/wechat-qr.svg" alt="微信二维码占位图" />
        <p>请替换为真实微信二维码或微信号。</p>
      </article>
      <article class="media-card">
        <p class="card-kicker">Sponsor</p>
        <h3>资助二维码</h3>
        <img class="qr" src="/media/sponsor-qr.svg" alt="资助二维码占位图" />
        <p>可以替换为赞赏码、收款码或项目资助入口。</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Video</p>
      <h2>自媒体视频平台</h2>
      <p>先保留入口，等你确定平台主页后替换链接。</p>
    </div>
    <div class="grid-3">
      {site.mediaLinks.map((link) => (
        <article class="card">
          <p class="card-kicker">Video Channel</p>
          <h3>{link.label}</h3>
          <p>{link.note}</p>
          <a class="text-link" href={link.href}>访问平台</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
